---
import Default from '@astrojs/starlight/components/TableOfContents.astro';

const { entry } = Astro.locals.starlightRoute;
const data = entry.data as Record<string, unknown>;
const ingredients = data.recipeIngredients as string | undefined;
const cookware = data.recipeCookware as string | undefined;
const recipeYield = data.recipeYield as string | undefined;
---

{ingredients ? (
  <div id="recipe-sidebar">
    {recipeYield && (
      <div class="recipe-sidebar-section recipe-scale">
        <label for="scale-target">🍽 Quantité</label>
        <div class="input-group">
          <input
            type="number"
            id="scale-target"
            class="scale-input"
            value={recipeYield}
            data-base={recipeYield}
            step="10"
            min="10"
            autocomplete="off"
          />
          <span class="input-suffix">grammes</span>
        </div>
      </div>
    )}
    <div class="recipe-sidebar-section">
      <h2><span class="icon">🥘</span><span class="title">Ingrédients</span></h2>
      <Fragment set:html={ingredients} />
    </div>
    {cookware && (
      <div class="recipe-sidebar-section">
        <h2><span class="icon">🍳</span><span class="title">Matériel</span></h2>
        <Fragment set:html={cookware} />
      </div>
    )}
  </div>
) : (
  <Default />
)}

<script>
  const inputs = document.querySelectorAll<HTMLInputElement>('.scale-input');
  if (inputs.length > 0) {
    const baseYield = parseFloat(inputs[0].dataset.base ?? inputs[0].value);

    function applyScale(newYield: number) {
      if (isNaN(newYield) || newYield <= 0) return;
      const ratio = newYield / baseYield;
      inputs.forEach(inp => { inp.value = String(newYield); });
      document.querySelectorAll<HTMLElement>('.ingredient-qty[data-original]').forEach(el => {
        const original = parseFloat(el.dataset.original!);
        const unit = el.dataset.unit ?? '';
        const scaled = original * ratio;
        el.textContent = formatQty(scaled) + (unit ? ` ${unit}` : '');
        const recipeLink = el.closest('li.ingredient')?.querySelector<HTMLAnchorElement>('a.recipe-link');
        if (recipeLink) {
          const url = new URL(recipeLink.href);
          url.searchParams.set('scale', Math.round(scaled).toString());
          recipeLink.href = url.toString();
        }
      });
      document.querySelectorAll<HTMLElement>('.recipe-yield-value[data-original]').forEach(el => {
        const original = parseFloat(el.dataset.original!);
        el.textContent = formatQty(original * ratio) + 'g';
      });
    }

    const urlScale = new URLSearchParams(window.location.search).get('scale');
    applyScale(urlScale ? parseFloat(urlScale) : baseYield);

    inputs.forEach(inp => {
      inp.addEventListener('input', () => applyScale(parseFloat(inp.value)));
    });
  }

  function formatQty(n: number): string {
    if (n >= 100) return Math.round(n).toString();
    if (n >= 10) return (Math.round(n * 10) / 10).toString();
    return (Math.round(n * 100) / 100).toString();
  }
</script>
